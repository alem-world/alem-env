# ALEM environment-only image.
#
# Build:
#   docker build -f docker/Dockerfile.env -t alem-env .
#   docker build -f docker/Dockerfile.env --build-arg ALEM_ACCELERATOR=cuda12 -t alem-env:gpu .
#   docker build -f docker/Dockerfile.env --build-arg ALEM_EXTRAS=llm,play -t alem-env:extras .
#
# Run (system Python is used inside the container — no 'uv run' prefix needed):
#   docker run --rm alem-env                                         # smoke test (default CMD)
#   docker run --rm --gpus all alem-env:gpu                         # GPU smoke test
#   docker run --rm alem-env python examples/random_rl_agent.py --steps 20
#   docker run --rm alem-env python examples/llm_text_smoke.py --coord easy
#   docker run --rm -it alem-env bash                               # interactive shell

FROM python:3.12-slim

ARG ALEM_EXTRAS=""
ARG ALEM_ACCELERATOR="cpu"

ENV ALEM_ACCELERATOR=${ALEM_ACCELERATOR} \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_SYSTEM_CERTS=true

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && python -m pip install --no-cache-dir --upgrade pip uv

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY alem ./alem
COPY examples ./examples

RUN set -eux; \
    extras="${ALEM_EXTRAS}"; \
    # Human play (the `play` extra) opens a pygame window; its bundled SDL2 still
    # dlopens the X11/GL client libs at runtime, so install them for that build.
    case ",${extras}," in \
        *,play,*) \
            apt-get update; \
            apt-get install -y --no-install-recommends \
                libsdl2-2.0-0 libx11-6 libxext6 libgl1; \
            rm -rf /var/lib/apt/lists/*;; \
    esac; \
    if [ "${ALEM_ACCELERATOR}" = "cuda12" ] || [ "${ALEM_ACCELERATOR}" = "gpu" ]; then \
        extras="${extras:+${extras},}gpu"; \
    elif [ "${ALEM_ACCELERATOR}" != "cpu" ]; then \
        echo "Unknown ALEM_ACCELERATOR=${ALEM_ACCELERATOR}; expected cpu or cuda12"; \
        exit 1; \
    fi; \
    if [ -n "${extras}" ]; then \
        uv pip install --system --no-cache -e ".[${extras}]"; \
    else \
        uv pip install --system --no-cache -e .; \
    fi

CMD ["python", "-c", "import jax; from alem.alem_env import make_alem_env_from_name; env = make_alem_env_from_name('Alem-Coop-Symbolic'); print(f'ALEM env OK: {env.num_agents} agents, JAX {jax.__version__}, devices={jax.devices()}')"]
